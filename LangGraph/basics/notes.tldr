						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "A super-step can be considered a single iteration over the graph nodes. "
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "Nodes that run in parallel are part of the same super-step, "
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "while nodes that run sequentially belong to separate super-steps."
								}
							]
						}
					]
				}
			},
			"parentId": "page:page",
			"index": "aMJfMfOV",
